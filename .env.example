# .env.example — copy to .env and fill in your own values.
# .env is gitignored (see root .gitignore). NEVER commit a real key.
#
# 用法:
#   cp .env.example .env
#   # 编辑 .env, 填你自己的 API key
#   bash scripts/run_eval.sh --smoke

# ─── LLM (兼容 OpenAI 协议) ──────────────────────────────────────────────
# 比赛官方主推模型: gemma-4-31b
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_BASE_URL=http://60.171.65.125:30197/v1
OPENAI_MODEL=gemma-4-31b

# ─── Judge service ─────────────────────────────────────────────────────────
# scripts/run_eval.py 默认指向你启动的本机 judge_service 实例
JUDGE_SERVICE_URL=http://localhost:9000

# 远程 judge (例): 替换为你团队部署的实例
# JUDGE_SERVICE_URL=http://10.220.69.153:9666

# ─── Judge service 自身的环境 (启动 server.py 时需要) ──────────────────────
# JUDGE_REPO  = 比赛官方 lean 仓的绝对路径 (一般指向 submodule)
# JUDGE_REPO=/abs/path/to/etp-stage2-team/third_party/equational-theories-lean-stage2
# JUDGE_WORKERS=4
# JUDGE_DEFAULT_TIMEOUT_SECONDS=120
# JUDGE_TIMEOUT_CAP_SECONDS=180
# JUDGE_CACHE_PATH=judge_cache.sqlite
# LEAN_BIN=lean
# LAKE_BIN=lake

# ─── LLM 高级调参 (run_eval.py / run_generic.py 读取) ─────────────────────
# LLM_HTTP_TIMEOUT=900
# LLM_MAX_OUTPUT_TOKENS=8192
# SOLVER_TIMEOUT=300
# WORKERS=8

# ─── stellar_v3_e 专用 ────────────────────────────────────────────────────
# STELLAR_V3E_BUDGET=1800
# STELLAR_V3E_LLM_RESERVE=1800
